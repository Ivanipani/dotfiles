#!/bin/zsh

usage() {
  cat <<'EOF'
Usage: retry [options] <command>

Retry a command until it succeeds, sleeping between attempts.

Options:
  -p, --period <seconds>  Time to sleep between retries (default: 5)
  -h, --help              Show this help message

Examples:
  retry curl http://example.com
  retry -p 10 ./deploy.sh
  retry --period 2 pg_isready -h localhost
EOF
}

period=5

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      return 0 2>/dev/null || exit 0
      ;;
    -p|--period)
      period="$2"
      shift 2
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -eq 0 ]]; then
  # echo "Error: no command specified" >&2
  usage >&2
  return 0 2>/dev/null
fi

cmd="$*"
start=$(date +%s)
count=1
while ! eval "$cmd" ; do
  (( count++ ))
  echo "$(date '+%Y-%m-%d %H:%M:%S') - Failed"
  sleep "$period"
done

echo "$(date '+%Y-%m-%d %H:%M:%S') - Success after $count tries and $(( $(date +%s) - start ))s"
